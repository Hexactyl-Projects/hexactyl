{
    "version": 2,
    "name": "hexactyl-docs",
    "builds": [
        {
            "src": "**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "outputDirectory": ".",
    "framework": null
}
